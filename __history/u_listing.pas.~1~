procedure Tfrm_listing.btn_backClick(Sender: TObject);
begin

  dms_frm_main.Show;

end;

procedure Tfrm_listing.btn_contactClick(Sender: TObject);
var
  MailTo: string;
begin
  with dm_databasis do begin
    tbl_users.Open;

    if tbl_users.Locate('Username', dm_databasis.dmsTarget, []) then begin
      // Kyk of die email nil/null
      if not tbl_users.FieldByName('Email').IsNull then begin
        MessageDlg('Please wait while your email client is opening.', TMsgDlgType.mtInformation, [TMsgDlgBtn.mbOk], 0);
        MailTo := 'mailto:' + tbl_users.FieldByName('Email').AsString;
        ShellExecute(0, 'open', PChar(MailTo), nil, nil, SW_SHOWNORMAL);
      end
      else
        MessageDlg('This user has no email address on file.', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
    end
    else
      MessageDlg('User not found.', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);

    tbl_users.Close;
  end;
end;
procedure Tfrm_listing.btn_deleteClick(Sender: TObject);
var
  iResponse: Integer;
begin

  iResponse :=
      MessageDlg(
          'Are you sure you want to delete this listing?',
          TMsgDlgType.mtConfirmation,
          [TMsgDlgBtn.mbYes, TMsgDlgBtn.mbNo],
          0
      );

  if iResponse = mrYes then begin

    with dm_databasis do begin

      tbl_listings.Open;

      if tbl_listings.Locate('ID', dmsListing, []) then begin

        tbl_listings.Delete;

        MessageDlg('Listing deleted successfully', TMsgDlgType.mtInformation, [TMsgDlgBtn.mbOk], 0);

        dm_logger.logger.LogLine('Deleted listing: ' + dmsListing);
        dms_frm_main.Show;
        Hide;

      end;

    end;

  end;

end;

procedure Tfrm_listing.btn_reviewClick(Sender: TObject);
begin

  u_reviews.frm_reviews.dms_frm_main := self;
  u_reviews.frm_reviews.dms_secondary := self.dms_frm_main;
  u_reviews.frm_reviews.Show;
  Hide;

end;

