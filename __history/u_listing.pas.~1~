procedure Tfrm_listing.FormShow(Sender: TObject);
var
  ArrCopy: array of string;
  k, sQueer: string;
  iTel, i: integer;
  ObjListing: TListing;

begin

  // Stap 0: Die 2de ADOQuery

  //ShowMessage(dm_databasis.dmsListing);

  with dm_databasis do begin

    sQueer :=
        'SELECT ID AS Listing_ID, '
            + 'IIF((SELECT COUNT(*) '
            + 'FROM tbl_Reviews '
            + 'WHERE Listing_ID = tbl_Listings.ID) = 0, 0, '
            + '(SELECT AVG(Rating) '
            + 'FROM tbl_Reviews '
            + 'WHERE Listing_ID = tbl_Listings.ID)) AS Avg_Rating '
            + 'FROM tbl_Listings '
            + 'WHERE ID = '
            + (dmsListing)
            + ' ORDER BY ID';

    AQ2.Close;

    AQ2.SQL.Text := sQueer;

    AQ2.Active := true;
    AQ2.Open;

    if AQ2.RecordCount = 0 then begin
      MessageDlg('Listing not found in database.', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
      AQ2.Close;
      Exit;
    end;

  end;

  // Stap 1: Die delete button

  if dm_databasis.dmsTarget = dm_databasis.dmsUsername then begin
    btn_delete.Visible := True;
    btn_delete.Enabled := True;
  end
  else begin
    btn_delete.Enabled := false;
    btn_delete.Visible := false;
  end;

  //ShowMessage(dm_databasis.dmsListing);

  // Stap 2: Die data in vervanging

  // Initialiseer;
  iTel := 0;
  SetLength(ArrCopy, Length(ArrInit));

  // Clone die array
  for k in ArrInit do begin

    Arrcopy[iTel] := k;

    inc(iTel);

  end;

  mem_desc.lines.clear;

  ObjListing := TListing.Create;

  ObjListing.LoadFromID(dm_databasis.dmsListing);

  ArrCopy[0] := arrCopy[0].Replace('X', ObjListing.GetName);

  // DB werk met die Queery begin
  with dm_databasis do begin
    ArrCopy[1] := arrCopy[1].Replace('X', AQ2['Avg_Rating']);
    AQ2.Close;
  end;
  // Einde

  ArrCopy[2] := arrCopy[2].Replace('X', inttostr(ObjListing.GetID));
  ArrCopy[3] := arrCopy[3].Replace('X', dm_databasis.dmsTarget);
  ArrCopy[4] := arrCopy[4].Replace('X', floattostrf(ObjListing.GetPrice, ffcurrency, 8, 2));
  ArrCopy[5] := arrCopy[5].Replace('X', ObjListing.GetLocation);

  for i := 0 to 5 do begin

    mem_desc.Lines.Add(ArrCopy[i]);
    mem_desc.Lines.Add('');

  end;

  mem_desc.Lines.Add('Description:');
  mem_desc.Lines.Add(ObjListing.GetDesc);

  ObjListing.Free;

end;

