function HashPassword(const APassword, ASalt: string): string;
begin
  // Gebruik the salt as die HMAC key
  // Die funksie "hash" die password sodat iemand met databasis toegang nie almal se password kan sien.
  Result := THashSHA2.GetHMAC(APassword, ASalt, THashSHA2.TSHA2Version.SHA256);
end;

procedure Tfrm_start.btn_connectClick(Sender: TObject);
var
  BGekry: Boolean;
  sPassword, sHash, sCon: string;
begin
  sUsername := edt_username.Text;
  dm_databasis.dmsUsername := sUsername;

  sPassword := edt_password.Text;
  sHash := HashPassword(sPassword, 'Fashion_salt'); // Sien commnets op die funksie vir meer inligting

  BGekry := False;
  dm_databasis.arrSettings[1] := edt_IP.Text;

  // localhost
  if edt_IP.Text = 'localhost' then begin
    // Identifiseer user
    with dm_databasis do begin
      tbl_users.Open;

      if tbl_users.Locate('Username', sUsername, []) then begin
        if sHash = tbl_users['Password_Hash'] then begin
          u_main.frm_main.Show;
          Hide;
          dmsUsername := sUsername;
          dm_logger.logger.LogLine('Successfully logged in as ' + sUsername + '.');
        end
        else begin
          // FMX framework se message dialog werk anders
          MessageDlg('Wrong Username or Password', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
          dm_logger.logger.LogLine('Failed login, bad details.');
        end;
      end
      else begin
        MessageDlg('Wrong Username or Password', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
        dm_logger.logger.LogLine('Failed login, user not found.');
      end;

      tbl_users.Close;
    end;
  end
  else begin
    {
      Microsoft access support nie actually remote connections nie.
      Maar met so betjie rond speel en vavorsing het ek uitgevind dat ADOconnection
      nie net vir Microsoft access support nie.

      So hierdie gedeelte gaan die connection string vervang met 'n MySQL server.
      Indien U self 'n remote db will host, lees die relevante dokument in die Docs folder.
    }

    with dm_databasis do begin
      sCon :=
          'Driver={MySQL ODBC 8.0 Unicode Driver};'
              + 'Server=XX;'
              + 'Database=MyDB;'
              + 'User=FashionForward;'
              + 'Password=ServiceAccount;'
              + 'Option=3;';

      {
      So indien U nie bekend is met MySQL
      Dit benodig 'n username, password en server
      IP address om na te connect.

      So ons gaan die connection string bou
      sodat all daardie inligting by die user ontvang is;

      Die gebruiker se username en password sal gebruik word
      om te authenticate na db.


      }

      sCon := sCon.Replace('XX', edt_IP.Text); // Die server IP van die databasis

      con_db.ConnectionString := sCon;
      con_db.Connected := True;

      tbl_users.Active := True;
      tbl_Reviews.Active := True;
      tbl_Listings.Active := True;

      // Identifiseer user
      tbl_users.Open;

      if tbl_users.Locate('Username', sUsername, []) then begin
        if sHash = tbl_users['Password_Hash'] then begin
          u_main.frm_main.Show;
          Hide;
          dmsUsername := sUsername;
          dm_logger.logger.LogLine('Successfully logged in as ' + sUsername + '.');
        end
        else begin
          // FMX framework se message dialog werk anders
          MessageDlg('Wrong Username or Password', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
          dm_logger.logger.LogLine('Failed login, bad details.');
        end;
      end
      else begin
        MessageDlg('Wrong Username or Password', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
        dm_logger.logger.LogLine('Failed login, user not found.');
      end;

      tbl_users.Close;
    end;
  end;
end;

procedure Tfrm_start.btn_createClick(Sender: TObject);
var
  BGekry: Boolean;
  sPassword, sCon, sEmail: string;
begin

  sUsername := edt_username.Text;
  sPassword := edt_password.Text;
  dm_databasis.dmsUsername := sUsername;
  sEmail := inputbox('Email','Please enter an account email.','');

  // verifieer password (nommers, hoofletters, special chars, length)

  //  8 <= karakters
  if not ((sPassword.Length > 8) or (sPassword.Length = 8)) then begin
    MessageDlg('Password has to be longer than 8 charachters.', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
    exit;
  end;

  if not TRegEx.IsMatch(sPassword, '\d') then // Moes regex leer vir hierdie :]
  begin
    MessageDlg('Password must contain a number!', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
    exit;
  end;

  if not TRegEx.IsMatch(sPassword, '[!@#$%^&*()_+\-=\[\]{};'':"\\|,.<>\/?]') then begin
    MessageDlg('Password must contain a special charachter!', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
    exit;
  end;

  if edt_IP.text = 'localhost' then begin
    // gebruik localhost
    With dm_databasis do begin
      // Stap 0 , initiliseer
      tbl_users.Open;
      tbl_users.First;

      // Stap 1 toets of username klaar bestaan
      while (not tbl_users.Eof) and (not Bgekry) do begin
        if tbl_users['Username'] = sUsername then
          BGekry := True;
        tbl_users.Next;
      end;

      if BGekry then begin
        MessageDlg(
            'Username already exists!',
            TMsgDlgType.mtError,
            [TMsgDlgBtn.mbOk],
            0
        ); // Messagedlg werk so in FMX framework
        exit;
      end;

      // Stap 3, maak user
      tbl_users.Open;
      tbl_users.Insert;

      tbl_users['Username'] := sUsername;
      tbl_users['Password_Hash'] := HashPassword(sPassword, 'Fashion_salt');
      tbl_users['Email'] := sEmail;

      MessageDlg('User created successfully!', TMsgDlgType.mtInformation, [TMsgDlgBtn.mbOk], 0);

      u_main.frm_main.Show;
      Hide;

      dmsUsername := sUsername;

      tbl_users.Close;
    end;
  end
  else begin
    {
      Microsoft access support nie actually remote connections nie.
      Maar met so betjie rond speel en vavorsing het ek uitgevind dat ADOconnection
      nie net vir Microsoft access support nie.

      So hierdie gedeelte gaan die connection string vervang met 'n MySQL server.
      Indien U self 'n remote db will host, lees die relevante dokument in die Docs folder.
    }

    with dm_databasis do begin
      sCon :=
          'Driver={MySQL ODBC 8.0 Unicode Driver};'
              + 'Server=XX;'
              + 'Database=MyDB;'
              + 'User=FashionForward;' // Service account
              + 'Password=ServiceAccount;'
              + 'Option=3;';

      sCon := sCon.Replace('XX', edt_IP.Text); // Die server IP van die databasis

      con_db.ConnectionString := sCon;

      try
        con_db.Connected := True;
      except
        begin
          MessageDlg(
              'Could not connect to remote database at ' + edt_IP.Text,
              TMsgDlgType.mtError,
              [TMsgDlgBtn.mbOk],
              0
          );
          dm_logger.logger.LogLine('Remote connection failed');
          Exit;
        end;
      end;

      tbl_users.Active := True;
      tbl_Reviews.Active := True;
      tbl_Listings.Active := True;

      tbl_users.Open;
      if tbl_users.Locate('Username', sUsername, []) then begin
        MessageDlg('Username already exists on remote server!', TMsgDlgType.mtError, [TMsgDlgBtn.mbOk], 0);
        con_db.Connected := False;
        tbl_users.Close;
        exit;
      end;

      tbl_users.Insert;
      tbl_users['Username'] := sUsername;
      tbl_users['Password_Hash'] := HashPassword(sPassword, 'Fashion_salt');
      tbl_users['Email'] := sEmail;
      tbl_users.Post;

      MessageDlg(
          'User created successfully on remote server!' + #13 + 'You can now login with your credentials.',
          TMsgDlgType.mtInformation,
          [TMsgDlgBtn.mbOk],
          0
      );

      u_main.frm_main.Show;
      Hide;
      dmsUsername := sUsername;

    end;
  end;
end;

